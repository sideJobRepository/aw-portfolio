# ===========================================================================
#  /etc/aw-portfolio.env  (백엔드 systemd 환경변수 파일)
#
#  배포 스크립트가 이 파일을 새 서버 /etc/aw-portfolio.env 로 복사한다.
#  민감 정보가 들어가므로 권한은 600 으로 제한된다.
# ===========================================================================

# --- DB ---  (새 서버 로컬 MySQL 8 / 사용자 admin)
# 3306 은 카페24 프로덕션 MariaDB 가 SSH 포트포워딩으로 점유 중이므로
# aw-portfolio 전용 MySQL 은 3307 로 격리 설치되어 있다.
DB_URL=127.0.0.1
DB_PORT=3307
DB_USERNAME=admin
DB_PASSWORD=1011gkgl!

# --- 파일 저장소 (S3 → 로컬 디스크) ---
FILE_STORAGE_LOCATION=/home/awdesign/uploads
FILE_STORAGE_BASE_URL=https://alwaysdesign-portfolio.com/files
